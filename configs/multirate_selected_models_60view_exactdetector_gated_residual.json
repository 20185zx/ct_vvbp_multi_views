{
  "experiment_name": "multirate_vvbp_local_rank_60view_exactdetector_gated_residual",
  "model_names": [
    "exact detector geometry gated residual local rank center integral mlp, 10 epochs"
  ],
  "region_name": "center_256",
  "region": [128, 384, 128, 384],
  "dicom_folder": "full_1mm/L067/full_1mm",
  "results_folder": "cache/fanbeam_geometry",
  "save_dir": "outputs/multirate_vvbp_local_rank_exactdetector_gated_residual",
  "experiment": {
    "full_views": 60,
    "sparse_views": [60],

    "image_size": 512,
    "n_detec": 736,
    "d_detec": 1.3696,
    "d_voxel": 0.6641,
    "DSO": 595.0,
    "DOD": 490.6,

    "train_batch_size": 1,
    "patch_size": 3,
    "train_region": null,

    "cache_num_batches": null,
    "cache_pixels_per_slice": 8192,
    "cached_batch_size": 8192,
    "num_epochs": 10,

    "lr": 0.001,
    "weight_decay": 0.000001,
    "grad_clip": null,
    "chunk_size_eval": 8192,

    "rebuild_train_cache": true,
    "rebuild_eval_cache": true,
    "seed": 42,

    "geometry_residual": {
      "enabled": true,
      "mode": "gated_additive_residual",
      "gate_feature": "absG_R2",
      "residual_features": ["G_R2", "absG_R2"],
      "lambda_geo": 0.03,
      "learnable_gate_affine": true,
      "gate_a_init": 1.0,
      "gate_b_init": 0.0,
      "zero_init_residual_last_layer": true,
      "normalize_residual_features": true,
      "eps": 1e-8
    }
  }
}
